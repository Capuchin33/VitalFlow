# Copy to web/.env (that file is not committed)
# Values: Supabase → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# For GitHub Pages if the repo is https://user.github.io/VitalFlow/
# VITE_BASE=/VitalFlow/

# Password reset: in Supabase → Authentication → URL Configuration add Redirect URLs
# (e.g. http://localhost:5173/ and production URL) so the Reset password email opens the app.
